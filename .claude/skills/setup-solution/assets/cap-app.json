{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cap-app Asset",
  "description": "Schema for cap-app asset with inheritance from: cap-app → base-service → base",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Application name"
        },
        "labels": {
          "type": "object",
          "description": "Key-value labels for the application",
          "additionalProperties": {
            "type": "string"
          },
          "default": {
            "asset-kind": "service",
            "managed-by": "yaml-composer"
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Runtime type (nodejs, java, python, etc.)",
          "default": "cap"
        },
        "language": {
          "type": "string",
          "default": "nodejs",
          "enum": ["nodejs", "java"]
        },
        "version": {
          "type": "string",
          "default": "latest-lts"
        },
        "framework": {
          "type": "string",
          "const": "cap",
          "default": "cap"
        }
      }
    },
    "requires": {
      "type": "array",
      "description": "Asset dependencies (platform services, other assets, components, extensions)",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "Shorthand: equivalent to {name: <value>, service: <value>, kind: platform-service}"
          },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Local binding key / dependency name"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "platform-service",
                  "component",
                  "asset",
                  "n8n-workflow",
                  "mcp-server",
                  "agent",
                  "agent-extension",
                  "domain-model-extension",
                  "ord"
                ],
                "description": "Dependency kind"
              },
              "version": {
                "type": "string",
                "description": "Version constraint"
              },
              "service": {
                "type": "string",
                "description": "BTP service technical name. Used with kind: platform-service."
              },
              "plan": {
                "type": "string",
                "description": "Service plan. Used with kind: platform-service."
              },
              "parameters": {
                "type": "object",
                "additionalProperties": true,
                "description": "Service instance creation parameters. Used with kind: platform-service."
              },
              "lazy": {
                "type": "boolean",
                "default": true,
                "description": "If true (default), service instance is only created when bound to a component/container."
              },
              "bindingSecretKey": {
                "type": "string",
                "description": "Key inside the binding secret to expose. Used with kind: platform-service."
              },
              "bindingParameters": {
                "type": "object",
                "additionalProperties": true,
                "description": "Parameters passed to service binding creation. Used with kind: platform-service."
              },
              "creationTimeout": {
                "type": "string",
                "default": "10m",
                "description": "Timeout for service instance creation (Go duration). Used with kind: platform-service."
              },
              "asset": {
                "type": "string",
                "description": "Target asset name. Optional when on a contained item (defaults to containing asset)."
              },
              "ordId": {
                "type": "string",
                "description": "ORD ID for platform discoverability."
              },
              "workflowId": {
                "type": "string",
                "description": "Workflow ID for n8n-workflow dependencies."
              },
              "extensible": {
                "type": "boolean",
                "default": false,
                "description": "If true, the required agent exposes extension points. Used with kind: agent."
              }
            }
          }
        ]
      }
