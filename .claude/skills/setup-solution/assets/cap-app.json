      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU request (e.g., '100m', '1')",
              "default": "100m"
            },
            "memory": {
              "type": "string",
              "description": "Memory request (e.g., '256Mi', '1Gi')",
              "default": "256Mi"
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "description": "CPU limit",
              "default": "500m"
            },
            "memory": {
              "type": "string",
              "description": "Memory limit",
              "default": "512Mi"
            }
          }
        }
      }
    },
    "probes": {
      "type": "object",
      "description": "Health check probes",
      "properties": {
        "startup": {
          "type": "object",
          "description": "Startup probe configuration",
          "properties": {
            "path": {
              "type": "string",
              "description": "HTTP path for probe",
              "default": "/health"
            },
            "initialDelaySeconds": {
              "type": "integer",
              "description": "Delay before first probe"
            },
            "periodSeconds": {
              "type": "integer",
              "description": "How often to perform probe",
              "default": 5
            },
            "timeoutSeconds": {
              "type": "integer",
              "description": "Probe timeout",
              "default": 3
            },
            "successThreshold": {
              "type": "integer",
              "description": "Minimum consecutive successes"
            },
            "failureThreshold": {
              "type": "integer",
              "description": "Minimum consecutive failures",
              "default": 18
            }
