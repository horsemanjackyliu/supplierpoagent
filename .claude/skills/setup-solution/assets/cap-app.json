          "env": {
            "type": "object",
            "description": "Component-specific environment variables"
          },
          "resources": {
            "type": "object",
            "description": "Component-specific resource allocation",
            "properties": {
              "requests": {
                "type": "object",
                "properties": {
                  "cpu": {
                    "type": "string"
                  },
                  "memory": {
                    "type": "string"
                  }
                }
              },
              "limits": {
                "type": "object",
                "properties": {
                  "cpu": {
                    "type": "string"
                  },
                  "memory": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "custom": {
            "type": "object",
            "description": "Component-specific opaque config",
            "additionalProperties": true
          }
        }
      }
