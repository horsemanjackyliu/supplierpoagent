            "initialDelaySeconds": {
              "type": "integer",
              "description": "Delay before first probe",
              "default": 5
            },
            "periodSeconds": {
              "type": "integer",
              "description": "How often to perform probe",
              "default": 5
            },
            "timeoutSeconds": {
              "type": "integer",
              "description": "Probe timeout",
              "default": 3
            },
            "successThreshold": {
              "type": "integer",
