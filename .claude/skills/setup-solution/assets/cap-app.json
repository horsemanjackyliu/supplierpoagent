        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Component identifier"
          },
          "type": {
            "type": "string",
            "description": "Component type — determines which component-level defaults apply",
            "enum": ["srv", "hdi-deployer"],
            "default": "srv"
          },
          "buildPath": {
            "type": "string",
            "default": ".",
            "description": "Relative path to component source"
          },
          "port": {
            "type": "integer",
            "description": "Component-specific port"
          },
          "provides": {
            "type": "object",
            "description": "What this component provides/exposes",
            "properties": {
              "endpoints": {
                "type": "array",
                "description": "HTTP endpoints exposed by this component",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "description": "Endpoint path (e.g., /api/v1, /auth)"
                    },
                    "port": {
                      "type": "integer",
                      "description": "Port for this endpoint (overrides component port)"
                    },
                    "protocol": {
                      "type": "string",
                      "enum": ["http", "https", "grpc"],
                      "default": "http"
                    }
                  }
                }
              },
              "routes": {
                "type": "array",
                "description": "Routes provided by this component",
                "items": {
                  "type": "string"
                }
              },
              "protocols": {
                "type": "array",
                "description": "Communication protocols supported",
                "items": {
                  "type": "string"
                }
              },
              "ui": {
                "type": "object",
                "description": "UI-specific provides",
                "properties": {
                  "framework": {
                    "type": "string"
                  },
                  "routes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "requires": {
            "type": "array",
            "description": "Component dependencies (intra-asset, inter-asset, or platform services)",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Shorthand: equivalent to {name: <value>, service: <value>, kind: platform-service}"
                },
                {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Local binding key / dependency name"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "platform-service",
                        "component",
                        "asset",
                        "n8n-workflow",
                        "mcp-server",
                        "agent",
                        "agent-extension",
                        "domain-model-extension",
                        "ord"
                      ],
                      "description": "Dependency kind"
                    },
                    "version": {
                      "type": "string",
                      "description": "Version constraint"
                    },
                    "service": {
                      "type": "string",
                      "description": "BTP service technical name. Used with kind: platform-service."
                    },
                    "plan": {
                      "type": "string",
                      "description": "Service plan. Used with kind: platform-service."
                    },
                    "parameters": {
                      "type": "object",
                      "additionalProperties": true,
                      "description": "Service instance creation parameters. Used with kind: platform-service."
                    },
                    "lazy": {
                      "type": "boolean",
                      "default": true,
                      "description": "If true (default), service instance is only created when bound to a component/container."
                    },
                    "bindingSecretKey": {
                      "type": "string",
                      "description": "Key inside the binding secret to expose. Used with kind: platform-service."
                    },
                    "bindingParameters": {
                      "type": "object",
                      "additionalProperties": true,
                      "description": "Parameters passed to service binding creation. Used with kind: platform-service."
                    },
                    "creationTimeout": {
                      "type": "string",
                      "default": "10m",
                      "description": "Timeout for service instance creation (Go duration). Used with kind: platform-service."
                    },
                    "asset": {
                      "type": "string",
                      "description": "Target asset name. Optional when on a contained item (defaults to containing asset)."
                    },
                    "ordId": {
                      "type": "string",
                      "description": "ORD ID for platform discoverability."
                    },
                    "workflowId": {
                      "type": "string",
                      "description": "Workflow ID for n8n-workflow dependencies."
                    },
                    "extensible": {
                      "type": "boolean",
                      "default": false,
                      "description": "If true, the required agent exposes extension points. Used with kind: agent."
                    }
                  }
                }
